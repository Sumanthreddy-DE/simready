# Phase 2A ML artifacts (regenerate via scripts/generate_parametric_steps.py +
# scripts/auto_label.py + scripts/train.py)
data/parametric/
data/labels/
data/labels_fixtures/
data/labels_combined/
# Ignore weights/ contents, but track the tiny checkpoint + metrics so a fresh
# clone has a model and numbers. (Can't negate a file under a fully-ignored dir,
# so ignore the contents glob instead of the directory.)
weights/*
!weights/brepnet.pt
!weights/brepnet_meta.json
!weights/eval_fixtures.json
!weights/metrics.json

# Phase 3 real-world test data (download via scripts/download_grabcad_samples.py)
tests/data/grabcad/

# Path C wk-1 day 3 — RAG-lite corpus + index (regenerate via scripts/scrape_fea_docs.py + scripts/index_fea_docs.py)
data/fea_docs/
!data/fea_docs/sources.txt
data/fea_docs_index.json

# Path C wk-1 day 5 — copilot session transcripts
data/copilot_sessions/

# Path C wk-1 day 6 — degraded-synthetic STEPs (regenerate via scripts/generate_degraded_steps.py)
data/parametric_degraded/

# Path C wk-2 day 11 — colored-face PNG renders from analyze_geometry tool
data/copilot_renders/

# Path C wk-2 day 11 — uploads from the Streamlit copilot UI
data/copilot_uploads/

# Path C wk-3 — healed STEP exports from analyze_geometry tool
data/healed_steps/

# Path C wk-3 — fine-tune traces (regenerate via scripts/synth_tool_traces.py)
data/fine_tune/

# Path C wk-3 — eval / run logs (runtime, regenerated each run)
logs/

# Local agent harness scratch
.claude/
