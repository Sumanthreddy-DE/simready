# SimReady Copilot — OpenAI-compatible LLM credentials
# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Required: API key for an OpenAI-compatible endpoint.
# Works with OpenAI, OpenRouter, Anthropic-via-OpenRouter, local Ollama, etc.
OPENAI_API_KEY=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

# Optional: base URL override.
# - Leave blank for OpenAI direct.
# - OpenRouter: https://openrouter.ai/api/v1
# - Local Ollama (OpenAI shim): http://localhost:11434/v1
# - Anthropic via proxy: see your proxy's documentation.
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: default model name.
# - OpenAI: gpt-4o-mini, gpt-4o, gpt-4-turbo
# - OpenRouter: anthropic/claude-3.5-sonnet, openai/gpt-4o-mini, qwen/qwen-2.5-7b-instruct
# - Anthropic via proxy: claude-3-5-sonnet-20241022 or similar
# - Local Ollama: qwen2.5:3b-instruct, llama3.1:8b
OPENAI_MODEL=minimaxai/minimax-m2.7
